

def split_and_join(line):
    a=line.split(" ")   #split kia hai sab ko line already diya to line he apna statement hai
    result="-".join(a)  # "-" ka use krke mene - lga diya and last me join kr diya hai
    return result

if __name__ == '__main__':
    line = input()
    result = split_and_join(line)
    print(result)
